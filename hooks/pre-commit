#!/bin/bash
# Forge pre-commit hook
# Instalar: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# 1. No commitear secrets
SECRETS_PATTERN='AKIA[0-9A-Z]{16}|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36}|xoxb-[a-zA-Z0-9-]+'
if git diff --cached --diff-filter=ACM | grep -qE "$SECRETS_PATTERN"; then
  echo "🔴 FORGE: Possible secret detected in staged files!"
  echo "   Run: git diff --cached | grep -E '$SECRETS_PATTERN'"
  echo "   Use environment variables instead of hardcoding secrets."
  exit 1
fi

# 2. No commitear .env files
ENV_FILES=$(git diff --cached --name-only | grep -E '^\.env$|^\.env\.' | grep -v '.example\|.sample\|.template' || true)
if [ -n "$ENV_FILES" ]; then
  echo "🔴 FORGE: Attempting to commit .env file(s):"
  echo "   $ENV_FILES"
  echo "   Add to .gitignore: echo '.env' >> .gitignore"
  exit 1
fi

# 3. No commitear archivos frozen
if [ -f .forge/frozen-files.txt ]; then
  FROZEN=$(comm -12 <(git diff --cached --name-only | sort) <(sort .forge/frozen-files.txt) || true)
  if [ -n "$FROZEN" ]; then
    echo "🔴 FORGE: Attempting to modify frozen file(s):"
    echo "   $FROZEN"
    echo "   Remove from .forge/frozen-files.txt to unfreeze."
    exit 1
  fi
fi

# 4. Check syntax (TypeScript)
if command -v npx &>/dev/null && [ -f tsconfig.json ]; then
  TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.ts$\|\.tsx$' || true)
  if [ -n "$TS_FILES" ]; then
    npx tsc --noEmit --pretty 2>&1 | head -20 || {
      echo "🔴 FORGE: TypeScript compilation errors. Fix before committing."
      exit 1
    }
  fi
fi

echo "✅ FORGE: Pre-commit checks passed."
